{
  "compilerOptions": {
    /* =========================
       BASIC
    ========================= */
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    /* =========================
       MODULE
    ========================= */
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    /* =========================
       REACT / NEXT
    ========================= */
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    /* =========================
       IMPORTS
    ========================= */
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/components/*": [
        "./src/components/*"
      ],
      "@/sections/*": [
        "./src/components/sections/*"
      ],
      "@/layout/*": [
        "./src/components/layout/*"
      ],
      "@/ui/*": [
        "./src/components/ui/*"
      ],
      "@/lib/*": [
        "./src/lib/*"
      ],
      "@/hooks/*": [
        "./src/hooks/*"
      ],
      "@/styles/*": [
        "./src/styles/*"
      ],
      "@/assets/*": [
        "./src/assets/*"
      ],
      "@/public/*": [
        "./public/*"
      ],
      "@/types/*": [
        "./src/types/*"
      ],
      "@/data/*": [
        "./src/data/*"
      ]
    },
    /* =========================
       DX
    ========================= */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
